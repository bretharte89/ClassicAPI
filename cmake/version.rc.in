// Generated from cmake/version.rc.in by CMake configure_file().
// Stamps the PE VERSIONINFO resource so Explorer -> Properties -> Details
// and GetFileVersionInfo() report the same version as the CLASSIC_API_VERSION
// Lua global. Both derive from the CLASSICAPI_TAG (vMAJOR.MINOR.PATCH) cache
// var; an untagged dev build gets the 9999.99.99 "newer than everything"
// sentinel.

#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @CLASSICAPI_VER_MAJOR@,@CLASSICAPI_VER_MINOR@,@CLASSICAPI_VER_PATCH@,0
 PRODUCTVERSION @CLASSICAPI_VER_MAJOR@,@CLASSICAPI_VER_MINOR@,@CLASSICAPI_VER_PATCH@,0
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_DLL
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "ClassicAPI Team"
            VALUE "FileDescription",  "ClassicAPI - modern WoW API backport for 1.12.1"
            VALUE "FileVersion",      "@CLASSICAPI_VER_STRING@"
            VALUE "InternalName",     "ClassicAPI"
            VALUE "LegalCopyright",   "Licensed under GPLv3"
            VALUE "OriginalFilename", "ClassicAPI.dll"
            VALUE "ProductName",      "ClassicAPI"
            VALUE "ProductVersion",   "@CLASSICAPI_VER_STRING@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        // 0x0409 = U.S. English, 1200 = Unicode codepage.
        VALUE "Translation", 0x409, 1200
    END
END
